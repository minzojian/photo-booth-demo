{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "noEmit": true,
    "noUnusedLocals": false,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src", "electron.vite.config.ts"]
}
