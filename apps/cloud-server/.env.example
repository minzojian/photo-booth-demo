# =============================================================================
# Photo Booth Cloud Server — Environment Variables / 环境变量
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# ── Server / 服务端口 ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Database: MySQL / 数据库 ───────────────────────────────────────────────
# 请用 127.0.0.1 而非 localhost，避免 Unix socket 连接问题。
DATABASE_URL=mysql://root:your_password@127.0.0.1:3306/photo_booth

# ── JWT / JWT 密钥（生产必改）─────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-string


# ── Storage: Tencent Cloud COS / 腾讯云对象存储 ───────────────────────────
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=photo-booth-1234567890
COS_REGION=ap-chengdu

# ── Storage: AWS S3 (alternative platform / 备选平台) ─────────────────────
# Uncomment and fill in to switch to S3 provider.
# 如需切换到 S3，取消注释并填入。
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_REGION=us-east-1

# ── Storage: Common / 通用 ─────────────────────────────────────────────────
# Object key prefix for all uploads (must end with /)
# 上传对象键前缀（末尾需带 /）
KEY_PREFIX=projects/photo_booth/

# STS temporary credential duration (seconds) / STS 临时凭证有效期（秒）
STS_DURATION=1800

# ── CDN / CDN 公网访问域名 ────────────────────────────────────────────────
# Public base URL for uploaded files. Leave empty to use COS/S3 default URL.
# 上传文件公网访问基地址。留空则使用 COS/S3 默认地址。
CDN_BASE=
